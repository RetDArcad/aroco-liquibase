<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Feature: articles catalog -->

    <changeSet id="2.0.0.0-articles" author="aroco">
        <createTable tableName="articles">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(100)"/>
            <column name="sale_price" type="DOUBLE PRECISION"/>
            <column name="wholesale_price" type="DOUBLE PRECISION"/>
            <column name="familly_id" type="INTEGER"/>
            <column name="stock" type="INTEGER"/>
            <column name="minimum_quantity" type="INTEGER"/>
            <column name="customer_quantity" type="INTEGER"/>
            <column name="purchase_quantity" type="INTEGER"/>
            <column name="vat_id" type="INTEGER"/>
            <column name="creation_date" type="VARCHAR(32)"/>
            <column name="last_modification" type="VARCHAR(32)"/>
            <column name="last_modifier_id" type="INTEGER"/>
            <column name="deleted" type="INTEGER" defaultValueNumeric="0"/>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="articles" baseColumnNames="familly_id"
                referencedTableName="families" referencedColumnNames="id"
                constraintName="fk_articles_family"/>
    </changeSet>

    <changeSet id="2.0.0.0-article-desc" author="aroco">
        <createTable tableName="article_desc">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(4000)"/>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="article_desc" baseColumnNames="id"
                referencedTableName="articles" referencedColumnNames="id"
                constraintName="fk_article_desc_article"/>
    </changeSet>

    <changeSet id="2.0.0.0-article-providers" author="aroco">
        <createTable tableName="article_providers">
            <column name="article_id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="provider_id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="article_providers" baseColumnNames="article_id"
                referencedTableName="articles" referencedColumnNames="id"
                constraintName="fk_artiprov_article"/>
        <addForeignKeyConstraint
                baseTableName="article_providers" baseColumnNames="provider_id"
                referencedTableName="providers" referencedColumnNames="id"
                constraintName="fk_artiprov_provider"/>
    </changeSet>

    <changeSet id="2.0.0.0-order-lines" author="aroco">
        <createTable tableName="order_lines">
            <column name="order_id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_year" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="line" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="article_id" type="INTEGER"/>
            <column name="quantity" type="INTEGER"/>
            <column name="quantity_delivred" type="INTEGER"/>
            <column name="price" type="DOUBLE PRECISION"/>
            <column name="total" type="DOUBLE PRECISION"/>
            <column name="total_with_vat" type="DOUBLE PRECISION"/>
        </createTable>
        <addForeignKeyConstraint
                baseTableName="order_lines" baseColumnNames="order_id"
                referencedTableName="orders" referencedColumnNames="id"
                constraintName="fk_orderlines_order"/>
        <addForeignKeyConstraint
                baseTableName="order_lines" baseColumnNames="article_id"
                referencedTableName="articles" referencedColumnNames="id"
                constraintName="fk_orderlines_article"/>
    </changeSet>

